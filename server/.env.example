PORT=3001
NODE_ENV=development

# PostgreSQL
# Local: postgresql://postgres:postgres@localhost:5432/icon_shop
# AlwaysData: postgresql://sql-database:YOUR_PASSWORD%21@postgresql-sql-database.alwaysdata.net:5432/sql-database_icon_computers?sslmode=disable
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/icon_shop

# Session secret
SESSION_SECRET=change-this-to-a-random-string

# Admin credentials (change after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SHOP_EMAIL=shop@iconshop.co.ke

# Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880
